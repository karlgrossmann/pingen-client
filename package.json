{
  "name": "pingen-client",
  "version": "1.0.0",
  "description": "A community-maintained Node.js SDK for the Pingen API",
  "keywords": [
    "pingen",
    "pingen-sdk",
    "letters-api",
    "postal-mail",
    "pingen-api",
    "letters"
  ],
  "homepage": "https://github.com/karlgrossmann/pingen-client#readme",
  "bugs": {
    "url": "https://github.com/karlgrossmann/pingen-client/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karlgrossmann/pingen-client.git"
  },
  "license": "MIT",
  "author": "Karl Grossmann",
  "type": "commonjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "directories": {
    "test": "tests"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepublishOnly": "npm run clean && npm run lint && npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "module": "./dist/index.mjs"
}
